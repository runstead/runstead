{
  "name": "@runstead/testkit",
  "version": "0.0.0",
  "description": "Test helpers for Runstead fixtures and temporary workspaces.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@runstead/core": "workspace:*",
    "@runstead/runtime": "workspace:*"
  }
}
