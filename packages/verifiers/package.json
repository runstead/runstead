{
  "name": "@runstead/verifiers",
  "version": "0.0.0",
  "description": "Verifier command contracts for Runstead runtime integrations.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "zod": "catalog:"
  }
}
