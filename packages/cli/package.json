{
  "name": "@runstead/cli",
  "version": "0.0.0",
  "description": "Runstead command-line interface.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "runstead": "./dist/index.js",
    "team": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.15 <27"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --testTimeout=30000",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@runstead/core": "workspace:*",
    "@runstead/domain-packs": "workspace:*",
    "@runstead/governance": "workspace:*",
    "@runstead/runtime": "workspace:*",
    "@runstead/skills": "workspace:*",
    "@runstead/state-sqlite": "workspace:*",
    "commander": "catalog:",
    "yaml": "catalog:",
    "zod": "catalog:"
  }
}
